# OpenCode Web Wrapper — Environment Variables
# Copy this file to a local .env or export before running.
#
#   cp env.example .env
#   source .env
#   node server.js
#
# Or with PM2:
#   PORT=36788 OPCODE_PASSWORD=xxx ... pm2 start server.js --name opencode-wrapper

# Port the wrapper server listens on (default: 3000)
PORT=36788

# OpenCode backend URL (default: http://localhost:4096)
OPENCODE_URL=http://127.0.0.1:4096

# Password for web UI login. If empty, no authentication is required.
# ⚠️  Set a strong password, especially when exposing to the internet.
OPCODE_PASSWORD=change-me-to-a-strong-password

# Root directory for the file browser (add-project modal).
# Clients cannot browse above this path.
# Default: /home
BROWSE_ROOT=/home
